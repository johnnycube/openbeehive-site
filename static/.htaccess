# openbeehive.org — Apache config for the static SvelteKit build.

# Serve the branded, prerendered 404 page for unknown paths.
ErrorDocument 404 /404.html

# Correct MIME type for woff2 (some Apache setups lack it).
<IfModule mod_mime.c>
  AddType font/woff2 .woff2
</IfModule>

<IfModule mod_headers.c>
  # Self-hosted fonts: filenames are versioned (e.g. -v38-), safe to cache long.
  <FilesMatch "\.woff2$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # SvelteKit's hashed assets under /_app/immutable/ never change.
  <If "%{REQUEST_URI} =~ m#^/_app/immutable/#">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </If>

  # HTML should always be revalidated so deploys show up immediately.
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>
